{
  "name": "@sqlpro/cloudflare",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "packages/cloudflare/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm --filter @sqlpro/website build",
          "rm -rf packages/cloudflare/public/*",
          "cp -r apps/website/dist/* packages/cloudflare/public/"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["^build"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "wrangler dev",
        "cwd": "packages/cloudflare"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "wrangler deploy",
        "cwd": "packages/cloudflare"
      },
      "dependsOn": ["build"]
    },
    "deploy:production": {
      "executor": "nx:run-commands",
      "options": {
        "command": "wrangler deploy --env production",
        "cwd": "packages/cloudflare"
      },
      "dependsOn": ["build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "packages/cloudflare"
      }
    }
  },
  "tags": ["scope:cloudflare", "type:app"]
}
