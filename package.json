{
  "name": "quarry-monorepo",
  "version": "2.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "description": "Quarry Monorepo - Professional database manager for macOS",
  "author": {
    "name": "kunish",
    "email": "kunish.butt@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "build": "swift build --package-path apps/swiftui",
    "dev": "swift run --package-path apps/swiftui",
    "docs:build": "pnpm --filter @quarry/docs build",
    "docs:dev": "pnpm --filter @quarry/docs dev",
    "docs:preview": "pnpm --filter @quarry/docs preview",
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "prepare": "husky",
    "test": "swift test --package-path apps/swiftui"
  },
  "dependencies": {},
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint-react/eslint-plugin": "catalog:",
    "@quarry/tsconfig": "workspace:*",
    "@typescript/native-preview": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
