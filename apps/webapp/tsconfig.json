{
  "extends": "@quarry/tsconfig/web.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["../electron/src/renderer/src/*"],
      "@shared/*": ["../electron/src/shared/*"],
      "@app/*": ["../electron/src/renderer/src/app/*"],
      "@features/*": ["../electron/src/renderer/src/features/*"],
      "@shared-ui/*": ["../electron/src/renderer/src/shared/*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*",
    "../electron/src/renderer/src/**/*",
    "../electron/src/shared/**/*"
  ],
  "exclude": [
    "../electron/src/renderer/src/**/*.test.ts",
    "../electron/src/renderer/src/**/*.test.tsx"
  ]
}
