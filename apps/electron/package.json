{
  "name": "sqlpro-app",
  "version": "1.10.1",
  "description": "Professional SQLite database manager with SQLCipher support and diff preview",
  "author": {
    "name": "kunish",
    "email": "kunish.butt@gmail.com"
  },
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "build": "electron-vite build",
    "build:icons": "fish resources/generate-icons.fish",
    "build:linux": "pnpm run build && electron-builder --linux --config electron-builder.config.js",
    "build:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.js",
    "build:unpack": "pnpm run build && electron-builder --dir --config electron-builder.config.js",
    "build:win": "pnpm run build && electron-builder --win --config electron-builder.config.js",
    "release:upload": "bash scripts/upload-release.sh",
    "dev": "electron-vite dev",
    "dev:mock": "VITE_MOCK_MODE=true electron-vite dev",
    "preview": "electron-vite preview",
    "screenshots": "tsx scripts/capture-screenshots.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "typecheck:node": "tsgo --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsgo --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "typecheck:main": "tsgo --noEmit -p src/main/tsconfig.json"
  },
