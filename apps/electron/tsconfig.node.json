{
  "extends": "@quarry/tsconfig/node.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/main/*"],
      "@shared/*": ["./src/shared/*"],
      "@core/*": ["./src/main/core/*"],
      "@database/*": ["./src/main/database/*"],
      "@agent/*": ["./src/main/agent/*"],
      "@observability/*": ["./src/main/observability/*"],
      "@features/*": ["./src/main/features/*"],
      "@ipc/*": ["./src/main/ipc/*"],
      "@quarry/ipc-contracts": ["../../packages/ipc-contracts/src/index.ts"],
      "@quarry/ipc-contracts/*": ["../../packages/ipc-contracts/src/*"]
    }
  },
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "../../packages/ipc-contracts/src/**/*"
  ],
  "exclude": ["scripts/**/*"]
}
