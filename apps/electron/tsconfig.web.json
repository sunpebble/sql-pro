{
  "extends": "@sqlpro/tsconfig/web.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@app/*": ["./src/renderer/src/app/*"],
      "@shared-ui/*": ["./src/renderer/src/shared/*"]
    },
    "types": ["@testing-library/jest-dom", "vitest/globals"]
  },
  "include": ["src/renderer/src/**/*", "src/shared/**/*"],
  "exclude": ["src/renderer/src/**/*.test.ts", "src/renderer/src/**/*.test.tsx"]
}
